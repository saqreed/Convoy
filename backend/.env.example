# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/convoy?schema=public"

# JWT secret (min 32 chars)
JWT_SECRET="please_change_me_to_a_long_random_secret_key_32chars_min"

# App port
PORT=3000

# WebSocket security
WS_TTL_SECONDS=120
WS_MIN_PING_INTERVAL_MS=3000

# Routing provider (OSRM)
OSRM_BASE_URL="https://router.project-osrm.org"

# Geocoding provider (Nominatim)
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
